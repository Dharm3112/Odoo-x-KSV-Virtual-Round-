# ============================================================
# VendorBridge Backend - Environment Variables
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# --- Database (PostgreSQL via PgBouncer) ---
DATABASE_URL="postgresql://db_user:password@localhost:6432/vendorbridge?pgbouncer=true&schema=public"
DIRECT_URL="postgresql://db_user:password@localhost:5432/vendorbridge?schema=public"

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT (RS256 Asymmetric Keys) ---
# Generate keys using:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# --- AWS S3 / MinIO ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_password
S3_BUCKET_NAME=vendorbridge-bucket
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# --- Email (MailDev for local / SES for production) ---
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="VendorBridge ERP <noreply@vendorbridge.com>"

# --- Rate Limiting ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- Puppeteer ---
PUPPETEER_EXECUTABLE_PATH=
